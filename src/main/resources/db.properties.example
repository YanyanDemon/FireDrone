# 数据库连接配置模板
# 复制此文件为 db.properties 并填入真实信息
driver=com.mysql.cj.jdbc.Driver
url=jdbc:mysql://localhost:3306/你的数据库名?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
username=你的用户名
password=你的密码
pool.minIdle=2
pool.maxPoolSize=10
pool.connectionTimeout=30000
pool.idleTimeout=600000
pool.maxLifetime=1800000
